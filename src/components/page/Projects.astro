---
import { Badge } from "@/components/ui/badge";
import projectData from "@/utils/projects.json";
import { SvgComponentGlobal } from "./SvgIcons";

type ProjectStatus = "released" | "in_progress" | "completed";

const getStatusConfig = (status: ProjectStatus) => {
  const configs = {
    released: {
      label: "Released",
      className:
        "bg-emerald-500/20 text-emerald-400 border-emerald-500/30 hover:bg-emerald-500/30",
    },
    in_progress: {
      label: "In Progress",
      className:
        "bg-blue-500/20 text-blue-400 border-blue-500/30 hover:bg-blue-500/30",
    },
    completed: {
      label: "Completed",
      className:
        "bg-zinc-500/20 text-zinc-400 border-zinc-500/30 hover:bg-zinc-500/30",
    },
  };
  return configs[status] || configs.completed;
};
---

<section class="relative">
  <h2
    class="text-2xl font-bold mb-6 mt-20 flex justify-start items-center gap-3"
  >
    <div class="p-2 rounded-lg bg-emerald-500/10">
      <SvgComponentGlobal icon="BOOK" className="w-5 h-5 text-emerald-400" />
    </div>
    <span>Projects</span>
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    {
      projectData.map((project) => {
        const statusConfig = getStatusConfig(project.status as ProjectStatus);
        return (
            <article class="group relative flex flex-col rounded-2xl border border-white/[0.08] bg-card/30 backdrop-blur-sm overflow-hidden transition-all duration-500 hover:border-emerald-500/20 hover:bg-card/50 hover:shadow-xl hover:shadow-emerald-500/5 hover:-translate-y-1">
            {project.isFeatured && (
              <div class="absolute top-0 right-0 w-24 h-24 overflow-hidden">
                <div class="absolute top-3 -right-8 w-32 text-center text-[10px] font-semibold text-white bg-gradient-to-r from-amber-500 to-orange-500 transform rotate-45 py-1 shadow-lg">
                  Featured
                </div>
              </div>
            )}

            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-3 mb-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-2">
                    <h3 class="text-lg font-semibold tracking-tight truncate">
                      {project.title}
                    </h3>
                    <Badge className={statusConfig.className}>
                      {statusConfig.label}
                    </Badge>
                    {project.isOpenSource && (
                      <Badge className="bg-purple-500/20 text-purple-400 border-purple-500/30">
                        Open Source
                      </Badge>
                    )}
                  </div>
                </div>

                <div class="flex gap-2 shrink-0">
                  {project?.url.map(
                    (urlData: {
                      icon: string;
                      url: string;
                      isSolid: boolean;
                    }) => (
                      <a
                        href={urlData.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-2 rounded-xl bg-secondary/50 border border-border/50 transition-all duration-300 hover:bg-primary hover:text-primary-foreground hover:border-primary hover:scale-110 hover:shadow-lg hover:shadow-primary/20"
                      >
                        <SvgComponentGlobal
                          icon={urlData.icon}
                          className="w-5 h-5"
                          isSolid={urlData.isSolid}
                          strokeWidth={1.5}
                        />
                      </a>
                    )
                  )}
                </div>
              </div>

              <p class="text-sm text-muted-foreground leading-relaxed mb-6 line-clamp-3">
                {project.description}
              </p>

              <div class="mt-auto pt-4">
                <div class="relative overflow-hidden">
                  <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-card/80 to-transparent z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity" />
                  <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-card/80 to-transparent z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity" />

                  <div class="flex gap-2 animate-scroll-x hover:pause-animation">
                    {[...project.tags, ...project.tags].map((tag) => (
                      <div class="shrink-0 flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-white/[0.04] text-xs text-muted-foreground transition-colors hover:bg-white/[0.08] hover:text-foreground">
                        <img
                          class="w-3.5 h-3.5"
                          alt={tag.title}
                          src={`https://cdn.simpleicons.org/${tag.logo}`}
                          loading="lazy"
                        />
                        <span>{tag.title}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <div class="absolute inset-0 bg-gradient-to-t from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
          </article>
        );
      })
    }
  </div>
</section>
