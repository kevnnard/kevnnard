---
import { SvgComponentGlobal } from "@/components/page/SvgIcons.tsx";
---

<h2 class="text-2xl font-bold mb-6 mt-20 flex justify-start items-center gap-3">
  <div class="p-2 rounded-lg bg-emerald-500/10">
    <SvgComponentGlobal icon="PROFILE" className="w-5 h-5 text-emerald-400" />
  </div>
  <span>About me</span>
</h2>

<article
  class="flex flex-col md:flex-row justify-between items-center gap-10 md:gap-16"
>
  <div class="flex-1 flex flex-col gap-6">
    <p class="text-muted-foreground leading-relaxed">
      My name is <span class="text-foreground font-medium">Kevin Londono</span>,
      known in the field as <span class="text-emerald-400 font-semibold"
        >KEVNNARD</span
      >. Over the years, I've worked as a Full Stack developer with a
      specialized focus on JavaScript ecosystems and hybrid mobile applications.
    </p>
    <p class="text-muted-foreground leading-relaxed">
      My expertise spans both frontend and backend development, and I'm
      committed to creating efficient and cutting-edge technological solutions.
      My background includes diverse projects, allowing me to solidify strong
      skills and a deep understanding of the challenges in web and mobile app
      development.
    </p>
    <p class="text-muted-foreground leading-relaxed">
      I'm dedicated to staying updated on the latest trends and technologies to
      deliver quality solutions to my clients.
    </p>

    <div class="flex flex-wrap justify-center md:justify-start gap-3 pt-4">
      <a
        href="https://kevnnard.s3.amazonaws.com/CV_ES.pdf"
        target="_blank"
        download
        class="group inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/[0.04] border border-white/[0.08] text-sm font-medium transition-all hover:bg-emerald-500/10 hover:border-emerald-500/20 hover:text-emerald-400"
      >
        <SvgComponentGlobal
          icon="DOWNLOAD"
          className="w-4 h-4 transition-transform group-hover:-translate-y-0.5"
        />
        CV Espanol
      </a>
      <a
        href="https://kevnnard.s3.amazonaws.com/CV_EN.pdf"
        target="_blank"
        download
        class="group inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/[0.04] border border-white/[0.08] text-sm font-medium transition-all hover:bg-emerald-500/10 hover:border-emerald-500/20 hover:text-emerald-400"
      >
        <SvgComponentGlobal
          icon="DOWNLOAD"
          className="w-4 h-4 transition-transform group-hover:-translate-y-0.5"
        />
        CV English
      </a>
    </div>
  </div>

  <figure class="flex-shrink-0 flex justify-center">
    <div class="relative group">
      <div
        class="absolute -inset-1 bg-gradient-to-r from-emerald-500/20 to-emerald-500/0 rounded-full blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>
      <img
        src="https://github.com/kevnnard.png"
        alt="Kevnnard"
        class="relative w-56 h-56 md:w-64 md:h-64 rounded-full border-2 border-white/[0.08] transition-all duration-500 group-hover:border-emerald-500/30 group-hover:scale-105"
      />
    </div>
  </figure>
</article>
