---
import { Badge } from "@/components/ui/badge";
import experienceData from "@/utils/experience.json";
import { SvgComponentGlobal } from "./SvgIcons";
---

<section class="relative" id="experience">
  <h2
    class="text-2xl font-bold mb-6 mt-16 flex justify-start items-center gap-3"
  >
    <div class="p-2 rounded-lg bg-emerald-500/10">
      <SvgComponentGlobal icon="JOB" className="w-5 h-5 text-emerald-400" />
    </div>
    <span>Work Experience</span>
  </h2>

  <div class="relative">
    <div
      class="absolute left-[19px] top-0 bottom-0 w-px bg-gradient-to-b from-emerald-500/50 via-emerald-500/20 to-transparent"
    >
    </div>

    <div class="space-y-6">
      {
        experienceData.map((data) => (
          <article class="group relative pl-12">
            <div class="absolute left-0 top-1 flex items-center justify-center">
              <div class="relative">
                <div
                  class={`w-10 h-10 rounded-xl flex items-center justify-center transition-all duration-300 ${
                    data.isCurrent
                      ? "bg-emerald-500/20 border border-emerald-500/40 group-hover:bg-emerald-500/30 group-hover:border-emerald-500/60"
                      : "bg-white/[0.04] border border-white/[0.08] group-hover:bg-white/[0.08] group-hover:border-white/[0.12]"
                  }`}
                >
                  {data.isCurrent && (
                    <span class="absolute -top-1 -right-1 flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" />
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500" />
                    </span>
                  )}
                  <SvgComponentGlobal
                    icon="JOB"
                    className={`w-5 h-5 ${data.isCurrent ? "text-emerald-400" : "text-muted-foreground"}`}
                  />
                </div>
              </div>
            </div>

            <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 transition-all duration-300 hover:border-white/[0.1] hover:bg-white/[0.04]">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-xs text-muted-foreground font-medium">
                    {data.duration}
                  </span>
                  {data.isCurrent && (
                    <Badge className="bg-emerald-500/20 text-emerald-400 border-emerald-500/30 text-[10px] px-2 py-0">
                      Active
                    </Badge>
                  )}
                </div>
                <span class="text-xs text-muted-foreground/60">
                  {data.location}
                </span>
              </div>

              <a
                href={data.link}
                target="_blank"
                rel="noreferrer"
                class="group/link inline-flex items-center gap-2 mb-1"
              >
                <h3 class="text-base font-semibold text-foreground transition-colors group-hover/link:text-emerald-400">
                  {data.title}
                </h3>
                <SvgComponentGlobal
                  icon="ARROW_LINK"
                  className="w-3.5 h-3.5 text-muted-foreground transition-all group-hover/link:text-emerald-400 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5"
                />
              </a>

              <p class="text-sm text-emerald-400/80 font-medium mb-3">
                {data.company}
              </p>

              <p class="text-sm text-muted-foreground leading-relaxed mb-4 line-clamp-3 group-hover:line-clamp-none transition-all">
                {data.description}
              </p>

              {data.tags && (
                <div class="flex flex-wrap gap-1.5">
                  {data.tags.slice(0, 8).map((tag) => (
                    <span class="px-2 py-0.5 text-[10px] font-medium rounded-md bg-white/[0.04] text-muted-foreground/80 transition-colors hover:bg-white/[0.08] hover:text-foreground">
                      {tag}
                    </span>
                  ))}
                  {data.tags.length > 8 && (
                    <span class="px-2 py-0.5 text-[10px] font-medium rounded-md bg-emerald-500/10 text-emerald-400/80">
                      +{data.tags.length - 8}
                    </span>
                  )}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
